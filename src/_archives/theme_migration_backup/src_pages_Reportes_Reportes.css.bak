/* ==========================================================================
   PÁGINA DE REPORTES - CONSISTENTE CON OTRAS PÁGINAS
   ========================================================================== */

/* Layout principal - igual padding que Skills y Usuarios */
#modulo-reportes-root.dashboard {
  padding: 6px 6px;
  max-width: 100%;
  margin: 0;
  height: 100%;
  overflow-y: auto;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

/* Topbar - mismo estilo que Skills y Usuarios */
.rep-topbar {
  display: flex;
  align-items: center;
  gap: 10px;
  background: #ffffff;
  border: 1px solid #e2e8f0;
  border-radius: 12px;
  padding: 0 16px;
  min-height: 62px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.05);
  flex-wrap: wrap;
  flex-shrink: 0;
  overflow: visible;
  box-sizing: border-box;
}

.rep-topbar-logo {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.rep-topbar-logo img {
  height: 30px;
  width: auto;
  filter: drop-shadow(0 1px 3px rgba(0, 0, 0, 0.06));
}

.rep-topbar-divider {
  width: 1px;
  height: 34px;
  background: #e2e8f0;
  flex-shrink: 0;
}

.rep-topbar-field {
  display: flex;
  flex-direction: column;
  gap: 4px;
  min-width: 140px;
  flex: 1;
}

.rep-topbar-field label {
  font-size: 11px;
  font-weight: 600;
  color: #64748b;
  text-transform: uppercase;
  letter-spacing: 0.3px;
}

.rep-topbar-select,
.rep-topbar-select-multiple,
.rep-topbar-input {
  height: 34px;
  border: 1px solid #e2e8f0;
  border-radius: 7px;
  background: #f8fafc;
  font-size: 12.5px;
  padding: 0 10px;
  transition: all 0.2s;
  color: #374151;
}

.rep-topbar-select:hover,
.rep-topbar-select-multiple:hover,
.rep-topbar-input:hover {
  background: white;
  border-color: #cbd5e1;
}

.rep-topbar-select:focus,
.rep-topbar-select-multiple:focus,
.rep-topbar-input:focus {
  outline: none;
  border-color: #3b82f6;
  background: white;
  box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
}

.rep-topbar-select:disabled,
.rep-topbar-select-multiple:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.rep-topbar-select-multiple {
  min-height: 60px;
  padding: 6px 10px;
}

.rep-topbar-btn-generar {
  height: 34px;
  padding: 0 16px;
  border: none;
  border-radius: 8px;
  background: #4f46e5;
  color: white;
  font-size: 12.5px;
  font-weight: 600;
  cursor: pointer;
  white-space: nowrap;
  flex-shrink: 0;
  transition: background 0.15s;
}

.rep-topbar-btn-generar:hover {
  background: #4338ca;
}

.rep-topbar-btn-generar:disabled {
  background: #c7d2fe;
  cursor: not-allowed;
}

.rep-topbar-clear {
  height: 34px;
  width: 34px;
  border: 1px solid #e2e8f0;
  border-radius: 7px;
  background: #f8fafc;
  cursor: pointer;
  font-size: 15px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: border-color 0.15s, background 0.15s;
}

.rep-topbar-clear:hover {
  border-color: #94a3b8;
  background: #f1f5f9;
}

/* Pantalla de bienvenida */
.rep-welcome-screen {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
}

.rep-welcome-card {
  background: white;
  border-radius: 20px;
  padding: 40px;
  text-align: center;
  box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
  max-width: 400px;
}

.rep-welcome-logo {
  height: 60px;
  margin-bottom: 20px;
}

.rep-welcome-card h2 {
  margin: 0 0 12px;
  color: #1e293b;
  font-size: 24px;
  font-weight: 700;
}

.rep-welcome-card p {
  margin: 0;
  color: #64748b;
  font-size: 14px;
}

/* Resultados */
.rep-resultados {
  background: white;
  border: 1px solid #e2e8f0;
  border-radius: 12px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.05);
  overflow: hidden;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.rep-resultados-header {
  padding: 16px 20px;
  border-bottom: 1px solid #e2e8f0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #f8fafc;
}

.rep-resultados-header h3 {
  margin: 0;
  font-size: 16px;
  font-weight: 600;
  color: #1e293b;
}

.rep-btn-exportar {
  height: 32px;
  padding: 0 12px;
  border: 1px solid #e2e8f0;
  border-radius: 6px;
  background: white;
  color: #475569;
  font-size: 12px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s;
}

.rep-btn-exportar:hover {
  background: #f1f5f9;
  border-color: #cbd5e1;
}

.rep-table-wrapper {
  overflow: auto;
  flex: 1;
}

.rep-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 12px;
}

.rep-table th {
  background: #f8fafc;
  padding: 12px 8px;
  text-align: left;
  font-weight: 600;
  color: #374151;
  border-bottom: 1px solid #e2e8f0;
  position: sticky;
  top: 0;
  z-index: 10;
}

.rep-table td {
  padding: 8px;
  border-bottom: 1px solid #f1f5f9;
  color: #1e293b;
}

.rep-table tr:hover {
  background: #f8fafc;
}

/* Scroll personalizado */
.rep-table-wrapper::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}

.rep-table-wrapper::-webkit-scrollbar-track {
  background: #f1f5f9;
}

.rep-table-wrapper::-webkit-scrollbar-thumb {
  background: #cbd5e1;
  border-radius: 3px;
}

.rep-table-wrapper::-webkit-scrollbar-thumb:hover {
  background: #94a3b8;
}