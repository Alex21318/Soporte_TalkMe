/* ==========================================================================
   PÁGINA DE REPORTES - CONSISTENTE CON USUARIOS Y SKILLS
   ========================================================================== */

/* Layout principal - igual padding que Skills y Usuarios */
#modulo-reportes-root.dashboard {
  padding: 6px 6px;
  max-width: 100%;
  margin: 0;
  height: 100%;
  overflow-y: auto;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

/* Barra secundaria para filtros extra (ej: texto búsqueda resoluciones por palabra) */
.rep-subbar {
  display: flex;
  align-items: center;
  gap: 10px;
  background: #f8faff;
  border: 1px solid #e2e8f0;
  border-radius: 10px;
  padding: 8px 16px;
  flex-shrink: 0;
}

/* Topbar - mismo estilo que Skills y Usuarios */
.rep-topbar {
  display: flex;
  align-items: center;
  gap: 10px;
  background: #ffffff;
  border: 1px solid #e2e8f0;
  border-radius: 12px;
  padding: 0 16px;
  min-height: 62px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.05);
  flex-wrap: wrap;
  flex-shrink: 0;
  overflow: visible;
  box-sizing: border-box;
}

.rep-topbar-logo {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.rep-topbar-logo-img {
  height: 30px;
  width: auto;
  filter: drop-shadow(0 1px 3px rgba(0, 0, 0, 0.06));
}

.rep-topbar-divider {
  width: 1px;
  height: 34px;
  background: #e2e8f0;
  flex-shrink: 0;
}

.rep-topbar-field {
  display: flex;
  flex-direction: column;
  gap: 4px;
  min-width: 140px;
  flex: 1;
}

.rep-topbar-label {
  font-size: 11px;
  font-weight: 600;
  color: #64748b;
  text-transform: uppercase;
  letter-spacing: 0.3px;
}

.rep-topbar-select,
.rep-topbar-select-multiple,
.rep-topbar-input {
  height: 34px;
  border: 1px solid #e2e8f0;
  border-radius: 7px;
  background: #f8fafc;
  font-size: 12.5px;
  padding: 0 10px;
  transition: all 0.2s;
  color: #374151;
}

.rep-topbar-select:hover,
.rep-topbar-select-multiple:hover,
.rep-topbar-input:hover {
  background: white;
  border-color: #cbd5e1;
}

.rep-topbar-select:focus,
.rep-topbar-select-multiple:focus,
.rep-topbar-input:focus {
  outline: none;
  border-color: #3b82f6;
  background: white;
  box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
}

.rep-topbar-select:disabled,
.rep-topbar-select-multiple:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.rep-topbar-select-multiple {
  min-height: 60px;
  padding: 6px 10px;
}

/* Skills Dropdown con Checkboxes */
.rep-skills-field {
  position: relative;
  min-width: 200px;
}

.rep-skills-trigger {
  display: flex;
  align-items: center;
  justify-content: space-between;
  cursor: pointer;
  text-align: left;
  width: 100%;
}

.rep-skills-trigger:disabled {
  cursor: not-allowed;
  opacity: 0.5;
}

.rep-skills-arrow {
  font-size: 9px;
  color: #94a3b8;
  margin-left: 8px;
}

.rep-skills-dropdown {
  position: absolute;
  top: calc(100% + 4px);
  left: 0;
  right: 0;
  min-width: 280px;
  background: white;
  border: 1px solid #e2e8f0;
  border-radius: 8px;
  box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
  z-index: 9999;
  max-height: 350px;
  display: flex;
  flex-direction: column;
}

/* Dropdown de campañas: más ancho porque los títulos son largos */
.rep-campanias-dropdown {
  min-width: 420px;
}

/* Cuando un dropdown esta abierto, el campo padre debe estar sobre el resto
   del topbar para que el dropdown no quede tapado por hermanos */
.rep-skills-field {
  z-index: 1;
}
.rep-skills-field:has(.rep-skills-dropdown) {
  z-index: 10000;
}

.rep-skills-dropdown-header {
  padding: 8px;
  border-bottom: 1px solid #e2e8f0;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.rep-skills-search {
  height: 30px;
  border: 1px solid #e2e8f0;
  border-radius: 6px;
  padding: 0 10px;
  font-size: 12px;
  background: #f8fafc;
  outline: none;
  transition: all 0.15s;
}

.rep-skills-search:focus {
  background: white;
  border-color: #3b82f6;
  box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.1);
}

.rep-skills-actions {
  display: flex;
  gap: 6px;
}

.rep-skills-action-btn {
  flex: 1;
  height: 26px;
  border: 1px solid #e2e8f0;
  border-radius: 5px;
  background: #f8fafc;
  font-size: 11px;
  font-weight: 500;
  color: #475569;
  cursor: pointer;
  transition: all 0.15s;
}

.rep-skills-action-btn:hover {
  background: white;
  border-color: #3b82f6;
  color: #3b82f6;
}

.rep-skills-list {
  overflow-y: auto;
  flex: 1;
  padding: 4px 0;
}

.rep-skills-item {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 6px 12px;
  cursor: pointer;
  font-size: 12.5px;
  color: #374151;
  transition: background 0.1s;
}

.rep-skills-item:hover {
  background: #f1f5f9;
}

.rep-skills-item input[type="checkbox"] {
  cursor: pointer;
  width: 14px;
  height: 14px;
  accent-color: #4f46e5;
}

.rep-skills-item-name {
  flex: 1;
}

.rep-skills-default-badge {
  color: #f59e0b;
  font-size: 11px;
}

.rep-skills-empty {
  padding: 16px;
  text-align: center;
  color: #94a3b8;
  font-size: 12px;
}

.rep-skills-list::-webkit-scrollbar {
  width: 6px;
}

.rep-skills-list::-webkit-scrollbar-track {
  background: #f1f5f9;
}

.rep-skills-list::-webkit-scrollbar-thumb {
  background: #cbd5e1;
  border-radius: 3px;
}

.rep-topbar-btn-generar {
  height: 34px;
  padding: 0 16px;
  border: none;
  border-radius: 8px;
  background: #4f46e5;
  color: white;
  font-size: 12.5px;
  font-weight: 600;
  cursor: pointer;
  white-space: nowrap;
  flex-shrink: 0;
  transition: background 0.15s;
  display: inline-flex;
  align-items: center;
  gap: 6px;
}

.rep-topbar-btn-generar:hover {
  background: #4338ca;
}

.rep-topbar-btn-generar:disabled {
  background: #c7d2fe;
  cursor: not-allowed;
}

.rep-topbar-btn-exportar {
  height: 34px;
  padding: 0 12px;
  border: 1px solid #e2e8f0;
  border-radius: 7px;
  background: #f8fafc;
  color: #475569;
  font-size: 12.5px;
  font-weight: 500;
  cursor: pointer;
  white-space: nowrap;
  flex-shrink: 0;
  transition: all 0.2s;
  display: inline-flex;
  align-items: center;
  gap: 6px;
}

.rep-btn-icon {
  width: 16px;
  height: 16px;
  object-fit: contain;
}

.rep-topbar-btn-exportar:hover {
  background: white;
  border-color: #cbd5e1;
}

.rep-topbar-btn-exportar:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.rep-topbar-clear {
  height: 34px;
  width: 34px;
  border: 1px solid #e2e8f0;
  border-radius: 7px;
  background: #f8fafc;
  cursor: pointer;
  font-size: 15px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: border-color 0.15s, background 0.15s;
}

.rep-topbar-clear:hover {
  border-color: #94a3b8;
  background: #f1f5f9;
}

/* Pantalla de bienvenida */
.rep-welcome-screen {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
}

.rep-welcome-card {
  background: white;
  border-radius: 20px;
  padding: 40px;
  text-align: center;
  box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
  max-width: 500px;
}

.rep-welcome-logo {
  height: 60px;
  margin-bottom: 20px;
}

.rep-welcome-card h2 {
  margin: 0 0 12px;
  color: #1e293b;
  font-size: 24px;
  font-weight: 700;
}

.rep-welcome-card p {
  margin: 0 0 24px;
  color: #64748b;
  font-size: 14px;
}

.rep-welcome-steps {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-top: 24px;
}

.rep-welcome-step {
  display: flex;
  align-items: center;
  gap: 12px;
  text-align: left;
}

.rep-step-number {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 24px;
  height: 24px;
  background: #4f46e5;
  color: white;
  border-radius: 50%;
  font-size: 12px;
  font-weight: 600;
  flex-shrink: 0;
}

.rep-step-text {
  color: #374151;
  font-size: 13px;
}

/* Resultados */
.rep-resultados {
  background: white;
  border: 1px solid #e2e8f0;
  border-radius: 12px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.05);
  overflow: hidden;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.rep-resultados-header {
  padding: 16px 20px;
  border-bottom: 1px solid #e2e8f0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #f8fafc;
  flex-wrap: wrap;
  gap: 12px;
}

.rep-resultados-header h3 {
  margin: 0;
  font-size: 16px;
  font-weight: 600;
  color: #1e293b;
}

.rep-resultados-info {
  display: flex;
  gap: 16px;
  font-size: 12px;
  color: #64748b;
}

.rep-resultados-info span {
  padding: 4px 8px;
  background: #f1f5f9;
  border-radius: 4px;
  font-weight: 500;
}

.rep-table-wrapper {
  overflow: auto;
  flex: 1;
}

.rep-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 12px;
}

.rep-table th {
  background: #f8fafc;
  padding: 12px 8px;
  text-align: left;
  font-weight: 600;
  color: #374151;
  border-bottom: 1px solid #cbd5e1;
  border-right: 1px solid #e2e8f0;
  position: sticky;
  top: 0;
  z-index: 10;
  white-space: nowrap;
}

.rep-table th:last-child,
.rep-table td:last-child {
  border-right: none;
}

.rep-table td {
  padding: 8px;
  border-bottom: 1px solid #e2e8f0;
  border-right: 1px solid #e2e8f0;
  color: #1e293b;
  white-space: nowrap;
}

.rep-table tr:hover {
  background: #f8fafc;
}

/* =============================================
   Tabla estilo Aguamarina - TableStyleMedium6
   Encabezado: teal oscuro, filas alternadas
   ============================================= */
.rep-table-aguamarina th {
  background: #1F6B75;
  color: #ffffff;
  border-right: 1px solid #175f68;
  border-bottom: none;
  font-weight: 700;
  letter-spacing: 0.3px;
}

.rep-table-aguamarina th:last-child {
  border-right: none;
}

.rep-table-aguamarina tbody tr:nth-child(odd) td {
  background: #D6F0F3;
}

.rep-table-aguamarina tbody tr:nth-child(even) td {
  background: #ffffff;
}

.rep-table-aguamarina tbody tr:hover td {
  background: #a8dde4 !important;
}

.rep-table-aguamarina td {
  border-bottom: 1px solid #b0d9df;
  border-right: 1px solid #b0d9df;
  color: #0e2f34;
}

.rep-table-aguamarina td:last-child {
  border-right: none;
}

/* Scroll personalizado */
.rep-table-wrapper::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}

.rep-table-wrapper::-webkit-scrollbar-track {
  background: #f1f5f9;
}

.rep-table-wrapper::-webkit-scrollbar-thumb {
  background: #cbd5e1;
  border-radius: 3px;
}

.rep-table-wrapper::-webkit-scrollbar-thumb:hover {
  background: #94a3b8;
}

/* Paginacion */
.rep-pagination {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 10px 16px;
  border-top: 1px solid #e2e8f0;
  background: #f8fafc;
  flex-wrap: wrap;
  flex-shrink: 0;
}

.rep-page-btn {
  height: 30px;
  padding: 0 12px;
  border: 1px solid #e2e8f0;
  border-radius: 6px;
  background: white;
  color: #475569;
  font-size: 12px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.15s;
}

.rep-page-btn:hover:not(:disabled) {
  background: #4f46e5;
  color: white;
  border-color: #4f46e5;
}

.rep-page-btn:disabled {
  opacity: 0.4;
  cursor: not-allowed;
}

.rep-page-info {
  font-size: 12.5px;
  color: #475569;
  padding: 0 12px;
}

.rep-page-info strong {
  color: #1e293b;
}

/* Toast notifications */
.Toastify__toast-container {
  z-index: 9999;
}

.Toastify__toast--success {
  background: #10b981;
}

.Toastify__toast--error {
  background: #ef4444;
}

.Toastify__toast--info {
  background: #3b82f6;
}

/* Responsive */
@media (max-width: 1200px) {
  .rep-topbar-field {
    min-width: 120px;
  }
  
  .rep-resultados-info {
    flex-direction: column;
    gap: 8px;
  }
}

@media (max-width: 768px) {
  .rep-topbar {
    padding: 12px;
  }
  
  .rep-topbar-field {
    min-width: 100px;
  }
  
  .rep-welcome-card {
    padding: 24px;
    margin: 16px;
  }
  
  .rep-resultados-header {
    padding: 12px;
  }
  
  .rep-table {
    font-size: 11px;
  }
  
  .rep-table th,
  .rep-table td {
    padding: 6px;
  }
}

/* ==========================================================================
   CELDAS CON TEXTO LARGO - WRAP PARA NOTAS RÁPIDAS Y MENSAJES
   ========================================================================== */
.rep-table td {
  white-space: normal;
  word-wrap: break-word;
  max-width: 300px;
}

.rep-table td:first-child,
.rep-table td:nth-child(2) {
  max-width: 150px;
}

/* Columnas de texto largo (TEXTO, MENSAJE_FUERA_HORARIO) */
.rep-table td[data-column="TEXTO"],
.rep-table td[data-column="MENSAJE_FUERA_HORARIO"] {
  max-width: 400px;
  min-width: 200px;
}
