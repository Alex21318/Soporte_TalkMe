/* ═══════════════════════════════════════════════════════════════════════════════
   MÓDULO CREACIONES
   ═══════════════════════════════════════════════════════════════════════════════ */

/* Reset local */
#modulo-creaciones-root * {
  box-sizing: border-box;
}

#modulo-creaciones-root {
  display: flex;
  flex-direction: column;
  height: 100vh;
  width: 100%;
  min-width: 0;
  background: #f8fafc;
  font-family: system-ui, -apple-system, Segoe UI, Roboto, Ubuntu, Cantarell, Noto Sans, Helvetica, Arial, "Apple Color Emoji", "Segoe UI Emoji";
  color: #0f172a;
  overflow: hidden;
}

/* ── TOPBAR ── */
.cr-topbar {
  height: 64px;
  background: #ffffff;
  border-bottom: 1px solid #e2e8f0;
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 0 16px;
  flex-shrink: 0;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}

.cr-topbar-logo {
  display: flex;
  align-items: center;
}

.cr-topbar-logo-img {
  height: 36px;
  width: auto;
}

.cr-topbar-divider {
  width: 1px;
  height: 36px;
  background: #e2e8f0;
  margin: 0 4px;
}

.cr-topbar-filters {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12px;
}

.cr-topbar-title {
  font-size: 18px;
  font-weight: 600;
  color: #1e293b;
}

/* ── BODY ── */
.cr-body {
  display: flex;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  padding: 12px;
  gap: 12px;
}

/* ── SIDEBAR ── */
.cr-sidebar {
  width: 240px;
  flex-shrink: 0;
  background: #ffffff;
  border: 1px solid #e2e8f0;
  border-radius: 12px;
  display: flex;
  flex-direction: column;
  padding: 12px 8px;
  gap: 2px;
  overflow-y: auto;
}

.cr-sidebar-title {
  font-size: 10px;
  font-weight: 700;
  color: #94a3b8;
  text-transform: uppercase;
  letter-spacing: 0.6px;
  padding: 4px 10px 8px;
  margin: 0;
}

.cr-sidebar-item {
  display: flex;
  align-items: center;
  gap: 10px;
  width: 100%;
  padding: 10px 12px;
  border-radius: 10px;
  border: none;
  background: transparent;
  cursor: pointer;
  text-align: left;
  transition: all 0.15s ease;
  position: relative;
}

.cr-sidebar-item:hover {
  background: #f1f5f9;
  transform: translateX(2px);
}

.cr-sidebar-item.active {
  background: #eef2ff;
  box-shadow: 0 2px 8px rgba(99, 102, 241, 0.15);
}

.cr-sidebar-icon {
  font-size: 20px;
  flex-shrink: 0;
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cr-sidebar-icon img {
  width: 24px;
  height: 24px;
  object-fit: contain;
}

.cr-sidebar-labels {
  display: flex;
  flex-direction: column;
  gap: 1px;
  flex: 1;
  min-width: 0;
}

.cr-sidebar-label {
  font-size: 12px;
  font-weight: 600;
  color: #1e293b;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.cr-sidebar-item.active .cr-sidebar-label {
  color: #4f46e5;
}

.cr-sidebar-desc {
  font-size: 10px;
  color: #94a3b8;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.cr-sidebar-item.active .cr-sidebar-desc {
  color: #818cf8;
}

.cr-sidebar-arrow {
  font-size: 18px;
  color: #6366f1;
  font-weight: 700;
  flex-shrink: 0;
}

/* ── PANEL ── */
.cr-panel {
  flex: 1;
  width: 0;
  display: flex;
  flex-direction: column;
  background: #ffffff;
  border-radius: 12px;
  overflow: hidden;
  border: 1px solid #e2e8f0;
  min-width: 0; /* Importante para que el flex no desborde */
}

.cr-content {
  flex: 1;
  overflow-y: auto;
  overflow-x: hidden;
  padding: 16px;
  min-width: 0; /* Importante para que el flex no desborde */
}

/* ── WELCOME ── */
.cr-state-center {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
}

.cr-welcome-card {
  text-align: center;
  background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
  border-radius: 16px;
  padding: 48px 32px;
  max-width: 420px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.08);
}

.cr-welcome-logo {
  height: 64px;
  margin-bottom: 16px;
}

.cr-welcome-title {
  font-size: 22px;
  font-weight: 700;
  color: #0f172a;
  margin: 0 0 8px;
}

.cr-welcome-text {
  font-size: 14px;
  color: #64748b;
  margin: 0;
}

/* ═══════════════════════════════════════════════════════════════════════════════
   FORMULARIO CREACIÓN INSTANCIA
   ═══════════════════════════════════════════════════════════════════════════════ */

.cr-inst-container {
  width: 100%;
  max-width: 100%;
  padding: 0;
  box-sizing: border-box;
  overflow-x: hidden;
}

/* Layout: 1 columna por defecto (más seguro para evitar desbordamiento) */
.cr-inst-sections-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16px;
  margin-bottom: 16px;
}

/* Las secciones dentro del grid no tienen margen inferior porque el grid ya lo tiene */
.cr-inst-sections-grid .cr-inst-section {
  margin-bottom: 0;
}

/* En pantallas muy grandes (> 1600px) usar 2 columnas */
@media (min-width: 1600px) {
  .cr-inst-sections-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }
}

.cr-inst-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24px;
  padding-bottom: 16px;
  border-bottom: 2px solid #e2e8f0;
  flex-wrap: wrap;
  gap: 12px;
}

.cr-inst-header h2 {
  font-size: 20px;
  font-weight: 700;
  color: #1e293b;
  margin: 0;
  display: flex;
  align-items: center;
  gap: 10px;
}

.cr-inst-header-icon {
  width: 32px;
  height: 32px;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 16px;
}

.cr-inst-actions {
  display: flex;
  justify-content: flex-end;
  gap: 10px;
  flex-wrap: wrap;
  min-width: 0;
}

.cr-inst-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  padding: 10px 18px;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.15s ease;
  border: none;
  white-space: nowrap;
}

.cr-inst-btn-primary {
  background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
  color: white;
  box-shadow: 0 2px 8px rgba(99, 102, 241, 0.3);
}

.cr-inst-btn-primary:hover {
  transform: translateY(-1px);
  box-shadow: 0 4px 12px rgba(99, 102, 241, 0.4);
}

.cr-inst-btn-primary:disabled {
  opacity: 0.6;
  cursor: not-allowed;
  transform: none;
}

.cr-inst-btn-secondary {
  background: #f1f5f9;
  color: #475569;
  border: 1px solid #cbd5e1;
}

.cr-inst-btn-secondary:hover {
  background: #e2e8f0;
}

/* ── Secciones del formulario ── */
.cr-inst-section {
  background: #ffffff;
  border: 1px solid #e2e8f0;
  border-radius: 12px;
  margin-bottom: 20px;
  overflow: visible;
  min-width: 0;
  max-width: 100%;
  box-sizing: border-box;
}

.cr-inst-section-header {
  background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
  padding: 14px 18px;
  border-bottom: 1px solid #e2e8f0;
  display: flex;
  align-items: center;
  gap: 10px;
}

.cr-inst-section-header h3 {
  font-size: 14px;
  font-weight: 700;
  color: #1e293b;
  margin: 0;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.cr-inst-section-badge {
  background: #6366f1;
  color: white;
  font-size: 10px;
  padding: 2px 8px;
  border-radius: 12px;
  font-weight: 600;
}

.cr-inst-section-body {
  padding: 14px;
}

.cr-inst-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 12px;
  min-width: 0;
}

.cr-inst-grid-2 {
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
}

.cr-inst-grid-3 {
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
}

/* En pantallas medianas, grids internos de 2 columnas pasan a 1 */
@media (max-width: 1400px) {
  .cr-inst-grid-2 {
    grid-template-columns: 1fr;
  }
  
  .cr-inst-grid-3 {
    grid-template-columns: 1fr;
  }
}

/* Para secciones de ancho completo cuando sea necesario */
.cr-inst-section-full {
  grid-column: 1 / -1;
}

/* Elementos de ancho completo fuera del grid */
.cr-inst-result.cr-inst-section-full,
.cr-inst-loading.cr-inst-section-full {
  max-width: 100%;
  margin: 20px 0;
}

/* ── Campos ── */
.cr-inst-field {
  display: flex;
  flex-direction: column;
  gap: 6px;
  min-width: 0;
}

.cr-inst-field label {
  font-size: 12px;
  font-weight: 600;
  color: #475569;
  display: flex;
  align-items: center;
  gap: 4px;
}

.cr-inst-required::after {
  content: '*';
  color: #ef4444;
}

.cr-inst-field input,
.cr-inst-field select,
.cr-inst-field textarea {
  padding: 10px 12px;
  border: 1px solid #cbd5e1;
  border-radius: 8px;
  max-width: 100%;
  box-sizing: border-box;
  font-size: 13px;
  color: #1e293b;
  background: #ffffff;
  transition: all 0.15s ease;
}

.cr-inst-field input:focus,
.cr-inst-field select:focus,
.cr-inst-field textarea:focus {
  outline: none;
  border-color: #6366f1;
  box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
}

.cr-inst-field input:disabled,
.cr-inst-field select:disabled,
.cr-inst-field textarea:disabled {
  background: #f1f5f9;
  color: #64748b;
}

.cr-inst-field input::placeholder {
  color: #94a3b8;
}

/* Control de desbordamiento para textos */
.cr-inst-field input,
.cr-inst-field select {
  text-overflow: ellipsis;
  overflow: hidden;
}

.cr-inst-field-hint {
  font-size: 11px;
  color: #64748b;
  margin-top: 2px;
}

.cr-inst-field-error {
  font-size: 11px;
  color: #ef4444;
  margin-top: 2px;
}

/* ── Campo con fila (input + botón) ── */
.cr-inst-field-row {
  display: flex;
  gap: 8px;
  align-items: center;
  max-width: 100%;
}

.cr-inst-field-row .cr-inst-input-token {
  flex: 1;
  min-width: 0; /* Permite que el input se encoja */
  font-family: 'JetBrains Mono', 'Fira Code', monospace;
  font-size: 12px;
}

.cr-inst-field-row .cr-inst-btn-sm {
  flex-shrink: 0;
  white-space: nowrap;
}

/* ── Campos deshabilitados (auto) ── */
.cr-inst-field-disabled {
  background: #f8fafc !important;
  color: #64748b !important;
  cursor: not-allowed;
  border-color: #e2e8f0 !important;
}

/* ── Redes Sociales ── */
.cr-inst-redes-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 12px;
}

.cr-inst-red-card {
  border: 2px solid #e2e8f0;
  border-radius: 10px;
  padding: 14px;
  cursor: pointer;
  transition: all 0.15s ease;
  display: flex;
  align-items: center;
  gap: 12px;
}

.cr-inst-red-card:hover {
  border-color: #cbd5e1;
  background: #f8fafc;
}

.cr-inst-red-card.active {
  border-color: #6366f1;
  background: #eef2ff;
}

.cr-inst-red-icon {
  width: 40px;
  height: 40px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  background: #f1f5f9;
  flex-shrink: 0;
}

.cr-inst-red-icon img {
  width: 26px;
  height: 26px;
  object-fit: contain;
  display: block;
}

.cr-inst-red-card.active .cr-inst-red-icon {
  background: #6366f1;
  color: white;
}

.cr-inst-red-info {
  flex: 1;
}

.cr-inst-red-name {
  font-size: 13px;
  font-weight: 600;
  color: #1e293b;
}

.cr-inst-red-card.active .cr-inst-red-name {
  color: #4f46e5;
}

.cr-inst-red-id {
  font-size: 11px;
  color: #64748b;
}

.cr-inst-checkbox {
  width: 20px;
  height: 20px;
  border: 2px solid #cbd5e1;
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.15s ease;
}

.cr-inst-red-card.active .cr-inst-checkbox {
  background: #6366f1;
  border-color: #6366f1;
  color: white;
}

/* ── Preview SQL ── */
.cr-inst-preview {
  background: #1e293b;
  border-radius: 10px;
  overflow: hidden;
}

.cr-inst-preview-header {
  background: #0f172a;
  padding: 10px 14px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.cr-inst-preview-title {
  font-size: 12px;
  font-weight: 600;
  color: #94a3b8;
  display: flex;
  align-items: center;
  gap: 6px;
}

.cr-inst-preview-actions {
  display: flex;
  gap: 8px;
}

.cr-inst-btn-sm {
  padding: 6px 12px;
  font-size: 11px;
}

.cr-inst-preview-body {
  padding: 14px;
  max-height: 400px;
  overflow-y: auto;
  overflow-x: auto;
}

.cr-inst-sql-test {
  display: flex;
  flex-direction: column;
  gap: 6px;
  padding: 12px 14px;
  border-bottom: 1px solid rgba(255,255,255,0.12);
  font-size: 12px;
}

.cr-inst-sql-test.success {
  background: rgba(34, 197, 94, 0.14);
  color: #bbf7d0;
}

.cr-inst-sql-test.error {
  background: rgba(239, 68, 68, 0.14);
  color: #fecaca;
}

.cr-inst-sql-test code {
  display: block;
  padding: 8px;
  border-radius: 6px;
  background: rgba(15, 23, 42, 0.55);
  color: inherit;
  white-space: pre-wrap;
  word-break: break-word;
}

.cr-inst-preview-body pre {
  margin: 0;
  font-family: 'JetBrains Mono', 'Fira Code', 'Consolas', monospace;
  font-size: 12px;
  line-height: 1.5;
  color: #e2e8f0;
  white-space: pre;
  min-width: max-content;
}

.sql-keyword {
  color: #93c5fd;
  font-weight: 700;
}

.sql-table {
  color: #fbbf24;
  font-weight: 600;
}

.sql-variable {
  color: #c4b5fd;
}

.sql-string {
  color: #86efac;
}

.sql-comment {
  color: #94a3b8;
  font-style: italic;
}

.cr-inst-template-editor {
  border-color: #c4b5fd;
}

.cr-inst-template-help {
  margin: 0 0 10px;
  color: #475569;
  font-size: 13px;
}

.cr-inst-template-textarea {
  width: 100%;
  min-height: 360px;
  padding: 14px;
  border: 1px solid #cbd5e1;
  border-radius: 10px;
  background: #0f172a;
  color: #e2e8f0;
  font-family: 'JetBrains Mono', 'Fira Code', 'Consolas', monospace;
  font-size: 12px;
  line-height: 1.45;
  resize: vertical;
  outline: none;
}

.cr-inst-template-textarea:focus {
  border-color: #6366f1;
  box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.16);
}

.cr-inst-template-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  justify-content: flex-end;
  margin-top: 12px;
}

/* ── Resultado ── */
.cr-inst-result {
  background: #f0fdf4;
  border: 1px solid #86efac;
  border-radius: 10px;
  padding: 18px;
  margin-top: 20px;
}

.cr-inst-result.error {
  background: #fef2f2;
  border-color: #fca5a5;
}

.cr-inst-result h4 {
  font-size: 14px;
  font-weight: 700;
  color: #166534;
  margin: 0 0 12px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.cr-inst-result.error h4 {
  color: #991b1b;
}

.cr-inst-result-content {
  font-size: 13px;
  color: #374151;
  line-height: 1.6;
}

/* ── Loading ── */
.cr-inst-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px;
  gap: 12px;
}

.cr-inst-spinner {
  width: 32px;
  height: 32px;
  border: 3px solid #e2e8f0;
  border-top-color: #6366f1;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.cr-inst-loading-text {
  font-size: 13px;
  color: #64748b;
}

/* ── URLs Dinámicas (Configuración 4) ── */
.cr-inst-urls-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-top: 8px;
}

.cr-inst-url-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 10px 14px;
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 8px;
  transition: all 0.2s ease;
}

.cr-inst-url-item:hover {
  background: #f1f5f9;
  border-color: #cbd5e1;
}

.cr-inst-url-text {
  font-family: 'JetBrains Mono', 'Fira Code', monospace;
  font-size: 13px;
  color: #0f172a;
  word-break: break-all;
}

.cr-inst-url-add {
  display: flex;
  gap: 10px;
  align-items: stretch;
}

.cr-inst-url-input {
  flex: 1;
  padding: 10px 12px;
  border: 1px solid #cbd5e1;
  border-radius: 8px;
  font-size: 14px;
  outline: none;
  transition: all 0.2s ease;
}

.cr-inst-url-input:focus {
  border-color: #6366f1;
  box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.16);
}

.cr-inst-help-text {
  display: block;
  margin-top: 8px;
  color: #64748b;
  font-size: 12px;
}

.cr-inst-btn-small {
  padding: 6px 10px;
  font-size: 12px;
}

.cr-inst-btn-danger {
  background: #fee2e2;
  color: #dc2626;
  border: 1px solid #fecaca;
}

.cr-inst-btn-danger:hover:not(:disabled) {
  background: #fecaca;
}

/* ── Responsive ── */
@media (max-width: 768px) {
  .cr-sidebar {
    width: 200px;
  }

  .cr-inst-grid-2,
  .cr-inst-grid-3 {
    grid-template-columns: 1fr;
  }

  .cr-inst-redes-grid {
    grid-template-columns: 1fr;
  }
  
  .cr-inst-url-add {
    flex-direction: column;
  }
}

/* ── Tabla de Números Demos ──────────────────────────────────────────────── */
.cr-inst-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 13px;
}

.cr-inst-table th {
  background: #f1f5f9;
  padding: 12px 16px;
  text-align: left;
  font-weight: 600;
  color: #475569;
  border-bottom: 2px solid #e2e8f0;
  white-space: nowrap;
}

.cr-inst-table td {
  padding: 12px 16px;
  border-bottom: 1px solid #e2e8f0;
  vertical-align: middle;
}

.cr-inst-table tbody tr:hover {
  background: #f8fafc;
}

.cr-inst-table .fila-ocupada {
  background: #fef3c7;
}

.cr-inst-table .fila-ocupada:hover {
  background: #fde68a;
}

.estado-badge {
  display: inline-block;
  padding: 4px 10px;
  border-radius: 20px;
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
}

.estado-disponible {
  background: #dcfce7;
  color: #166534;
}

.estado-ocupado {
  background: #fee2e2;
  color: #991b1b;
}

.estado-inactivo {
  background: #e2e8f0;
  color: #475569;
}

.badge-ambiente {
  display: inline-block;
  padding: 3px 8px;
  border-radius: 4px;
  font-size: 11px;
  font-weight: 500;
  background: #e0e7ff;
  color: #3730a3;
}

.uso-info {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.uso-info small {
  font-size: 11px;
}

.uso-info .text-muted {
  color: #94a3b8;
}

.text-center {
  text-align: center;
}

.text-muted {
  color: #64748b;
}

.acciones-row {
  display: flex;
  gap: 6px;
}

.cr-inst-btn-success {
  background: #dcfce7;
  color: #166534;
  border: 1px solid #86efac;
}

.cr-inst-btn-success:hover:not(:disabled) {
  background: #86efac;
}

.cr-inst-grid-4 {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 16px;
}
